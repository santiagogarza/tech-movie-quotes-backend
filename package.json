{
  "name": "tech-movie-quotes-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hono HTTP API that proxies an expanded tech-movie-quotes catalog from a bundled stdio MCP server. Optional companion to tech-movie-quotes-frontend.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "mcp": "tsx src/mcp-server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
